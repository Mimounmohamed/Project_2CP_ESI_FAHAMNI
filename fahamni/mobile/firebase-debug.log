[debug] [2026-05-05T01:25:00.734Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/fahamni-dev/rulesets {"name":"projects/fahamni-dev/rulesets/6be06f06-5a07-4673-9593-580943686da1","source":{"files":[{"content":"rules_version = '2';\r\nservice firebase.storage {\r\n  match /b/{bucket}/o {\r\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isAdmin() {\n      return signedIn() &&\n        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));\n    }\n\n    function conversationData(chatId) {\r\n      return firestore.get(\r\n        /databases/(default)/documents/conversations/$(chatId)\r\n      ).data;\r\n    }\r\n\r\n    function isParticipant(chatId) {\r\n      return signedIn() &&\r\n        conversationData(chatId).participants is list &&\r\n        request.auth.uid in conversationData(chatId).participants;\r\n    }\r\n\r\n    function isLegacyOwner(chatId) {\r\n      return signedIn() &&\r\n        conversationData(chatId).user_uid is string &&\r\n        conversationData(chatId).user_uid == request.auth.uid;\r\n    }\r\n\r\n    function canAccessChat(chatId) {\r\n      return isParticipant(chatId) || isLegacyOwner(chatId);\r\n    }\r\n\r\n    // --- VOICE FEATURE START ---\r\n    match /chats/{chatId}/voice/{fileId} {\r\n      allow read, write: if canAccessChat(chatId);\r\n    }\r\n    // --- VOICE FEATURE END ---\r\n\r\n    // --- ATTACHMENT FEATURE START ---\r\n    match /chats/{chatId}/attachments/{fileId} {\n      allow read, write: if canAccessChat(chatId);\n    }\n    // --- ATTACHMENT FEATURE END ---\n\n    match /tutor_certifications/{tutorId}/{fileName=**} {\n      allow read: if signedIn() && (request.auth.uid == tutorId || isAdmin());\n      allow write: if signedIn() && request.auth.uid == tutorId;\n    }\n  }\n}\n","name":"storage.rules"}]},"createTime":"2026-05-05T01:24:55.638319Z","metadata":{"services":["firebase.storage"]}}
