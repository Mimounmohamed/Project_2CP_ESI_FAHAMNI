[debug] [2026-05-05T01:25:03.250Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/fahamni-dev/rulesets {"name":"projects/fahamni-dev/rulesets/463a347d-975b-4803-923c-8426fd292fdf","source":{"files":[{"content":"rules_version = '2';\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    function signedIn() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    function isSelf(userId) {\r\n      return signedIn() && request.auth.uid == userId;\r\n    }\r\n\r\n    function conversationData(conversationId) {\r\n      return get(/databases/$(database)/documents/conversations/$(conversationId)).data;\r\n    }\r\n\r\n    function isConversationParticipantResource() {\r\n      return signedIn() &&\r\n        resource.data.participants is list &&\r\n        request.auth.uid in resource.data.participants;\r\n    }\r\n\r\n    function isLegacyConversationOwnerResource() {\r\n      return signedIn() &&\r\n        resource.data.user_uid is string &&\r\n        resource.data.user_uid == request.auth.uid;\r\n    }\r\n\r\n    function isConversationParticipant(conversationId) {\r\n      return signedIn() &&\r\n        conversationData(conversationId).participants is list &&\r\n        request.auth.uid in conversationData(conversationId).participants;\r\n    }\r\n\r\n    function isLegacyConversationOwner(conversationId) {\r\n      return signedIn() &&\r\n        conversationData(conversationId).user_uid is string &&\r\n        conversationData(conversationId).user_uid == request.auth.uid;\r\n    }\r\n\r\n    function canAccessConversation(conversationId) {\r\n      return isConversationParticipant(conversationId) ||\r\n        isLegacyConversationOwner(conversationId);\r\n    }\r\n\r\n    function conversationDataAfter(conversationId) {\r\n      return getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data;\r\n    }\r\n\r\n    function isConversationParticipantAfter(conversationId) {\r\n      return signedIn() &&\r\n        conversationDataAfter(conversationId).participants is list &&\r\n        request.auth.uid in conversationDataAfter(conversationId).participants;\r\n    }\r\n\r\n    function requestHasParticipant() {\r\n      return signedIn() &&\r\n        request.resource.data.participants is list &&\r\n        request.auth.uid in request.resource.data.participants;\r\n    }\r\n\r\n    function isTutorResourceOwner() {\r\n      return signedIn() &&\r\n        resource.data.tutor_id is string &&\r\n        resource.data.tutor_id == request.auth.uid;\r\n    }\r\n\r\n    function isTutorWriteOwner() {\r\n      return signedIn() &&\r\n        request.resource.data.tutor_id is string &&\r\n        request.resource.data.tutor_id == request.auth.uid;\r\n    }\r\n\r\n    function isAdmin() {\r\n      return signedIn() &&\r\n        exists(/databases/$(database)/documents/admins/$(request.auth.uid));\r\n    }\r\n\r\n    function parentChildIds() {\r\n      return (\r\n        exists(/databases/$(database)/documents/parents/$(request.auth.uid)) &&\r\n        get(/databases/$(database)/documents/parents/$(request.auth.uid)).data.children_uids is list\r\n      )\r\n        ? get(/databases/$(database)/documents/parents/$(request.auth.uid)).data.children_uids\r\n        : [];\r\n    }\r\n\r\n    function isStudentServiceJoinRequest() {\r\n      return signedIn() &&\r\n        request.resource.data.pending_ids is list &&\r\n        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pending_ids', 'updated_at']) &&\r\n        (\r\n          !('pending_ids' in resource.data) ||\r\n          resource.data.pending_ids is list\r\n        ) &&\r\n        (\r\n          !('student_ids' in resource.data) ||\r\n          resource.data.student_ids is list\r\n        ) &&\r\n        request.resource.data.pending_ids.size() ==\r\n          (\r\n            ('pending_ids' in resource.data && resource.data.pending_ids is list)\r\n              ? resource.data.pending_ids.size()\r\n              : 0\r\n          ) + 1 &&\r\n        request.resource.data.pending_ids.hasAll(\r\n          ('pending_ids' in resource.data && resource.data.pending_ids is list)\r\n            ? resource.data.pending_ids\r\n            : []\r\n        ) &&\r\n        (\r\n          request.auth.uid in request.resource.data.pending_ids ||\r\n          request.resource.data.pending_ids.hasAny(parentChildIds())\r\n        );\r\n    }\r\n\r\n    // Public lookups are required for registration and phone-based login.\r\n    // These collections are queried by email or phone before the client user\r\n    // has signed in, so read access is allowed for unauthenticated users.\r\n    match /users/{userId} {\n      allow read: if true;\n      allow write: if isSelf(userId) || isAdmin();\n    }\n\r\n    match /students/{userId} {\r\n      allow read: if true;\r\n      allow write: if isSelf(userId) || isAdmin();\r\n    }\r\n\r\n    match /tutors/{userId} {\r\n      allow read: if true;\r\n      allow write: if isSelf(userId) || isAdmin();\r\n      // Allow updating average_rating when submitting reviews\r\n      allow update: if signedIn() && \r\n        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['average_rating']);\r\n    }\r\n\r\n    match /parents/{userId} {\r\n      allow read: if true;\r\n      allow write: if isSelf(userId) || isAdmin();\r\n    }\r\n\r\n    match /conversations/{conversationId} {\r\n      // Allow reads for signed-in users\r\n      // The client-side query with where(participants contains userId) \r\n      // ensures only their conversations are returned\r\n      allow read: if signedIn();\r\n      \r\n      allow create: if requestHasParticipant();\r\n      allow update: if canAccessConversation(conversationId);\r\n      allow delete: if false;\r\n\r\n      match /messages/{messageId} {\r\n        // Allow message reads if user is a conversation participant\r\n        allow read: if signedIn() && canAccessConversation(conversationId);\r\n        allow create: if signedIn() && \r\n          isConversationParticipantAfter(conversationId) &&\r\n          request.resource.data.senderId == request.auth.uid;\r\n        allow update, delete: if false;\r\n      }\r\n    }\r\n\r\n    match /notifications/{notificationId} {\r\n      allow read: if signedIn() &&\r\n        resource.data.receiver_id == request.auth.uid;\r\n      allow create: if signedIn() &&\r\n        request.resource.data.receiver_id is string;\r\n      allow update, delete: if signedIn() &&\r\n        resource.data.receiver_id == request.auth.uid;\r\n    }\r\n\r\n    match /reviews/{reviewId} {\r\n      allow read: if signedIn();\r\n      allow create: if signedIn();\r\n      allow update: if signedIn();\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /quotes/{quoteId} {\r\n      allow read: if signedIn();\r\n      allow create: if signedIn();\r\n      allow update: if signedIn();\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /quote_requests/{quoteId} {\r\n      allow read: if signedIn();\r\n      allow create: if signedIn();\r\n      allow update: if signedIn();\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /services/{serviceId} {\r\n      allow read: if signedIn();\r\n      allow create: if isTutorWriteOwner() || isAdmin();\r\n      allow update: if isTutorResourceOwner() || isAdmin() || isStudentServiceJoinRequest();\r\n      allow delete: if isTutorResourceOwner() || isAdmin();\r\n    }\r\n\r\n    match /admins/{adminId} {\r\n      allow read: if signedIn();\r\n      allow write: if isSelf(adminId);\r\n    }\r\n\r\n    match /sessions/{sessionId} {\r\n      allow read: if signedIn();\r\n      allow create: if isTutorWriteOwner() || isAdmin();\r\n      allow update, delete: if isTutorResourceOwner() || isAdmin();\r\n    }\r\n\r\n    match /feedbacks/{feedbackId} {\r\n      allow read: if signedIn();\r\n      allow create: if signedIn();\r\n      allow update: if isAdmin();\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /reports/{reportId} {\r\n      allow read: if signedIn();\r\n      allow create: if signedIn();\r\n      allow update: if isAdmin();\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /resources/{resourceId} {\r\n      allow read: if signedIn();\r\n      allow create: if isTutorWriteOwner();\r\n      allow update, delete: if isTutorResourceOwner();\r\n    }\r\n\r\n    match /children/{childId} {\r\n      allow read: if signedIn();\r\n      allow create: if isAdmin() || (signedIn() && request.resource.data.parentUid == request.auth.uid);\r\n      allow update, delete: if isAdmin() || (signedIn() && resource.data.parentUid == request.auth.uid);\r\n    }\r\n\r\n    match /rejections/{rejectionId} {\r\n      allow read: if isAdmin();\r\n      allow create: if isAdmin();\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    // Email OTP collection for verification codes\r\n    match /email_otps/{email} {\r\n      // Allow unauthenticated users to write OTP during signup/login\r\n      // Allow authenticated users to write for email updates\r\n      allow write: if true;\r\n      allow read: if request.auth != null || request.auth == null;\r\n      allow delete: if true;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-05-05T01:24:58.139823Z","metadata":{"services":["cloud.firestore"]}}
