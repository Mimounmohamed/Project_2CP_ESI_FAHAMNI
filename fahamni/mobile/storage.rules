rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function conversationData(chatId) {
      return firestore.get(
        /databases/(default)/documents/conversations/$(chatId)
      ).data;
    }

    function isParticipant(chatId) {
      return signedIn() &&
        conversationData(chatId).participants is list &&
        request.auth.uid in conversationData(chatId).participants;
    }

    function isLegacyOwner(chatId) {
      return signedIn() &&
        conversationData(chatId).user_uid is string &&
        conversationData(chatId).user_uid == request.auth.uid;
    }

    function canAccessChat(chatId) {
      return isParticipant(chatId) || isLegacyOwner(chatId);
    }

    // --- VOICE FEATURE START ---
    match /chats/{chatId}/voice/{fileId} {
      allow read, write: if canAccessChat(chatId);
    }
    // --- VOICE FEATURE END ---

    // --- ATTACHMENT FEATURE START ---
    match /chats/{chatId}/attachments/{fileId} {
      allow read, write: if canAccessChat(chatId);
    }
    // --- ATTACHMENT FEATURE END ---
  }
}
