rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function conversationData(conversationId) {
      return get(/databases/$(database)/documents/conversations/$(conversationId)).data;
    }

    function isConversationParticipantResource() {
      return signedIn() &&
        resource.data.participants is list &&
        request.auth.uid in resource.data.participants;
    }

    function isLegacyConversationOwnerResource() {
      return signedIn() &&
        resource.data.user_uid is string &&
        resource.data.user_uid == request.auth.uid;
    }

    function isConversationParticipant(conversationId) {
      return signedIn() &&
        conversationData(conversationId).participants is list &&
        request.auth.uid in conversationData(conversationId).participants;
    }

    function isLegacyConversationOwner(conversationId) {
      return signedIn() &&
        conversationData(conversationId).user_uid is string &&
        conversationData(conversationId).user_uid == request.auth.uid;
    }

    function canAccessConversation(conversationId) {
      return isConversationParticipant(conversationId) ||
        isLegacyConversationOwner(conversationId);
    }

    function conversationDataAfter(conversationId) {
      return getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data;
    }

    function isConversationParticipantAfter(conversationId) {
      return signedIn() &&
        conversationDataAfter(conversationId).participants is list &&
        request.auth.uid in conversationDataAfter(conversationId).participants;
    }

    function requestHasParticipant() {
      return signedIn() &&
        request.resource.data.participants is list &&
        request.auth.uid in request.resource.data.participants;
    }

    function isTutorResourceOwner() {
      return signedIn() &&
        resource.data.tutor_id is string &&
        resource.data.tutor_id == request.auth.uid;
    }

    function isTutorWriteOwner() {
      return signedIn() &&
        request.resource.data.tutor_id is string &&
        request.resource.data.tutor_id == request.auth.uid;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function parentChildIds() {
      return (
        exists(/databases/$(database)/documents/parents/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/parents/$(request.auth.uid)).data.children_uids is list
      )
        ? get(/databases/$(database)/documents/parents/$(request.auth.uid)).data.children_uids
        : [];
    }

    function isStudentServiceJoinRequest() {
      return signedIn() &&
        request.resource.data.pending_ids is list &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pending_ids', 'updated_at']) &&
        (
          !('pending_ids' in resource.data) ||
          resource.data.pending_ids is list
        ) &&
        (
          !('student_ids' in resource.data) ||
          resource.data.student_ids is list
        ) &&
        request.resource.data.pending_ids.size() ==
          (
            ('pending_ids' in resource.data && resource.data.pending_ids is list)
              ? resource.data.pending_ids.size()
              : 0
          ) + 1 &&
        request.resource.data.pending_ids.hasAll(
          ('pending_ids' in resource.data && resource.data.pending_ids is list)
            ? resource.data.pending_ids
            : []
        ) &&
        (
          request.auth.uid in request.resource.data.pending_ids ||
          request.resource.data.pending_ids.hasAny(parentChildIds())
        );
    }

    // Public lookups are required for registration and phone-based login.
    // These collections are queried by email or phone before the client user
    // has signed in, so read access is allowed for unauthenticated users.
    match /users/{userId} {
      allow read: if true;
      allow write: if isSelf(userId) || isAdmin();
    }

    match /students/{userId} {
      allow read: if true;
      allow write: if isSelf(userId) || isAdmin();
    }

    match /tutors/{userId} {
      allow read: if true;
      allow write: if isSelf(userId) || isAdmin();
      // Allow updating average_rating when submitting reviews
      allow update: if signedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['average_rating']);
    }

    match /parents/{userId} {
      allow read: if true;
      allow write: if isSelf(userId) || isAdmin();
    }

    match /conversations/{conversationId} {
      // Allow reads for signed-in users
      // The client-side query with where(participants contains userId) 
      // ensures only their conversations are returned
      allow read: if signedIn();
      
      allow create: if requestHasParticipant();
      allow update: if canAccessConversation(conversationId);
      allow delete: if false;

      match /messages/{messageId} {
        // Allow message reads if user is a conversation participant
        allow read: if signedIn() && canAccessConversation(conversationId);
        allow create: if signedIn() && 
          isConversationParticipantAfter(conversationId) &&
          request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() &&
        resource.data.receiver_id == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.receiver_id is string;
      allow update, delete: if signedIn() &&
        resource.data.receiver_id == request.auth.uid;
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if false;
    }

    match /quotes/{quoteId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if false;
    }

    match /quote_requests/{quoteId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if false;
    }

    match /services/{serviceId} {
      allow read: if signedIn();
      allow create: if isTutorWriteOwner() || isAdmin();
      allow update: if isTutorResourceOwner() || isAdmin() || isStudentServiceJoinRequest();
      allow delete: if isTutorResourceOwner() || isAdmin();
    }

    match /admins/{adminId} {
      allow read: if signedIn();
      allow write: if isSelf(adminId);
    }

    match /sessions/{sessionId} {
      allow read: if signedIn();
      allow create: if isTutorWriteOwner() || isAdmin();
      allow update, delete: if isTutorResourceOwner() || isAdmin();
    }

    match /feedbacks/{feedbackId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /reports/{reportId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /resources/{resourceId} {
      allow read: if signedIn();
      allow create: if isTutorWriteOwner();
      allow update, delete: if isTutorResourceOwner();
    }

    match /children/{childId} {
      allow read: if signedIn();
      allow create: if isAdmin() || (signedIn() && request.resource.data.parentUid == request.auth.uid);
      allow update, delete: if isAdmin() || (signedIn() && resource.data.parentUid == request.auth.uid);
    }

    match /rejections/{rejectionId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Email OTP collection for verification codes
    match /email_otps/{email} {
      // Allow unauthenticated users to write OTP during signup/login
      // Allow authenticated users to write for email updates
      allow write: if true;
      allow read: if request.auth != null || request.auth == null;
      allow delete: if true;
    }
  }
}
