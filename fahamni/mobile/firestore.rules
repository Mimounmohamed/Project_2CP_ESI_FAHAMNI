rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function conversationData(conversationId) {
      return get(/databases/$(database)/documents/conversations/$(conversationId)).data;
    }

    function isConversationParticipant(conversationId) {
      return signedIn() &&
        request.auth.uid in conversationData(conversationId).participants;
    }

    function requestHasParticipant() {
      return signedIn() &&
        request.resource.data.participants is list &&
        request.auth.uid in request.resource.data.participants;
    }

    function isTutorResourceOwner() {
      return signedIn() &&
        resource.data.tutor_id is string &&
        resource.data.tutor_id == request.auth.uid;
    }

    function isTutorWriteOwner() {
      return signedIn() &&
        request.resource.data.tutor_id is string &&
        request.resource.data.tutor_id == request.auth.uid;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow write: if isSelf(userId);
    }

    match /students/{userId} {
      allow read: if signedIn();
      allow write: if isSelf(userId) || isAdmin();
    }

    match /tutors/{userId} {
      allow read: if signedIn();
      allow write: if isSelf(userId) || isAdmin();
    }

    match /parents/{userId} {
      allow read: if signedIn();
      allow write: if isSelf(userId) || isAdmin();
    }

    match /conversations/{conversationId} {
      allow read: if isConversationParticipant(conversationId);
      allow create: if requestHasParticipant();
      allow update: if isConversationParticipant(conversationId);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);
        allow create: if isConversationParticipant(conversationId) &&
          request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() &&
        resource.data.receiver_id == request.auth.uid;
      allow create: if signedIn() &&
        request.resource.data.receiver_id is string;
      allow update, delete: if signedIn() &&
        resource.data.receiver_id == request.auth.uid;
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if false;
    }

    match /quotes/{quoteId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if false;
    }

    match /quote_requests/{quoteId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if false;
    }

    match /services/{serviceId} {
      allow read: if signedIn();
      allow create: if isTutorWriteOwner() || isAdmin();
      allow update, delete: if isTutorResourceOwner() || isAdmin();
    }

    match /admins/{adminId} {
      allow read: if signedIn();
      allow write: if isSelf(adminId);
    }

    match /sessions/{sessionId} {
      allow read: if signedIn();
      allow create: if isTutorWriteOwner() || isAdmin();
      allow update, delete: if isTutorResourceOwner() || isAdmin();
    }

    match /feedbacks/{feedbackId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /reports/{reportId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /resources/{resourceId} {
      allow read: if signedIn();
      allow create: if isTutorWriteOwner();
      allow update, delete: if isTutorResourceOwner();
    }

    match /children/{childId} {
      allow read: if signedIn();
      allow create: if isAdmin() || (signedIn() && request.resource.data.parentUid == request.auth.uid);
      allow update, delete: if isAdmin() || (signedIn() && resource.data.parentUid == request.auth.uid);
    }

    match /rejections/{rejectionId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
