[debug] [2026-04-19T00:14:53.984Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/fahamni-dev/rulesets {"name":"projects/fahamni-dev/rulesets/c95b8269-ca49-49ec-ae7e-9790fb273ab0","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isSelf(userId) {\n      return signedIn() && request.auth.uid == userId;\n    }\n\n    function conversationData(conversationId) {\n      return get(/databases/$(database)/documents/conversations/$(conversationId)).data;\n    }\n\n    function isConversationParticipant(conversationId) {\n      return signedIn() &&\n        request.auth.uid in conversationData(conversationId).participants;\n    }\n\n    function requestHasParticipant() {\n      return signedIn() &&\n        request.resource.data.participants is list &&\n        request.auth.uid in request.resource.data.participants;\n    }\n\n    function isTutorResourceOwner() {\n      return signedIn() &&\n        resource.data.tutor_id is string &&\n        resource.data.tutor_id == request.auth.uid;\n    }\n\n    function isTutorWriteOwner() {\n      return signedIn() &&\n        request.resource.data.tutor_id is string &&\n        request.resource.data.tutor_id == request.auth.uid;\n    }\n\n    match /users/{userId} {\n      allow read: if signedIn();\n      allow write: if isSelf(userId);\n    }\n\n    match /students/{userId} {\n      allow read: if signedIn();\n      allow write: if isSelf(userId);\n    }\n\n    match /tutors/{userId} {\n      allow read: if signedIn();\n      allow write: if isSelf(userId);\n    }\n\n    match /parents/{userId} {\n      allow read: if signedIn();\n      allow write: if isSelf(userId);\n    }\n\n    match /conversations/{conversationId} {\n      allow read: if isConversationParticipant(conversationId);\n      allow create: if requestHasParticipant();\n      allow update: if isConversationParticipant(conversationId);\n      allow delete: if false;\n\n      match /messages/{messageId} {\n        allow read: if isConversationParticipant(conversationId);\n        allow create: if isConversationParticipant(conversationId) &&\n          request.resource.data.senderId == request.auth.uid;\n        allow update, delete: if false;\n      }\n    }\n\n    match /notifications/{notificationId} {\n      allow read: if signedIn() &&\n        resource.data.receiver_id == request.auth.uid;\n      allow create: if signedIn() &&\n        request.resource.data.receiver_id is string;\n      allow update, delete: if signedIn() &&\n        resource.data.receiver_id == request.auth.uid;\n    }\n\n    match /reviews/{reviewId} {\n      allow read: if signedIn();\n      allow create: if signedIn();\n      allow update: if signedIn();\n      allow delete: if false;\n    }\n\n    match /quotes/{quoteId} {\n      allow read: if signedIn();\n      allow create: if signedIn();\n      allow update: if signedIn();\n      allow delete: if false;\n    }\n\n    match /quote_requests/{quoteId} {\n      allow read: if signedIn();\n      allow create: if signedIn();\n      allow update: if signedIn();\n      allow delete: if false;\n    }\n\n    match /services/{serviceId} {\n      allow read: if signedIn();\n      allow create: if isTutorWriteOwner();\n      allow update, delete: if isTutorResourceOwner();\n    }\n\n    match /sessions/{sessionId} {\n      allow read: if signedIn();\n      allow create: if isTutorWriteOwner();\n      allow update, delete: if isTutorResourceOwner();\n    }\n\n    match /resources/{resourceId} {\n      allow read: if signedIn();\n      allow create: if isTutorWriteOwner();\n      allow update, delete: if isTutorResourceOwner();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-19T00:14:53.912271Z","metadata":{"services":["cloud.firestore"]}}
